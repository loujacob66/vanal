# Ollama settings
OLLAMA_URL=http://localhost:11434
VISION_MODEL=moondream
TEXT_MODEL=llama3

# Database
DATABASE_URL=data/vanal.db

# Frame extraction
FRAMES_DIR=frames
MAX_FRAMES_PER_CLIP=3
FRAME_WIDTH=256

# Ingestion
INGEST_DELAY_SECS=1.0

# Transcription (requires: pip install openai-whisper)
ENABLE_TRANSCRIPTION=false
WHISPER_MODEL=base

# Output directory for rendered montages
OUTPUT_DIR=./outputs

# Web UI password — leave blank to disable auth entirely (fine for local use)
# Set a password if you expose the server on a network
WEB_PASSWORD=

# Sora downloader (sora_download.py)
# Comma-separated API keys; optionally add :Label after each key
# SORA_API_KEYS=sk-key1:AccountA,sk-key2:AccountB
SORA_DOWNLOAD_DIR=./sora_downloads
